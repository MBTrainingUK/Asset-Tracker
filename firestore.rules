rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns the calling user's adminUsers document data
    function adminData() {
      return get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data;
    }

    // True if the user is a superAdmin (global access across all tenants)
    function isSuperAdmin() {
      return request.auth != null && adminData().superAdmin == true;
    }

    // True if the user is an approved admin/member for exactly this tenant
    function isTenantUser(tenantId) {
      return request.auth != null
        && adminData().status == 'approved'
        && adminData().tenantId == tenantId;
    }

    // True if the user is an approved admin for this tenant (or superAdmin)
    function isTenantAdmin(tenantId) {
      return isSuperAdmin()
        || (isTenantUser(tenantId) && adminData().role == 'admin');
    }

    // True if the user can access this tenant at all (superAdmin or assigned tenant member)
    function canAccessTenant(tenantId) {
      return isSuperAdmin() || isTenantUser(tenantId);
    }

    // -------------------------------------------------------------------------
    // Tenant documents — readable by any authenticated user (needed for switcher)
    // -------------------------------------------------------------------------
    match /tenants/{tenantId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // -------------------------------------------------------------------------
    // Tenant-scoped: assets
    // -------------------------------------------------------------------------
    match /tenants/{tenantId}/assets/{assetId} {
      allow read: if canAccessTenant(tenantId);
      allow create: if isTenantAdmin(tenantId) || (canAccessTenant(tenantId) && validAssetWrite(request.resource.data));
      allow update: if isTenantAdmin(tenantId) || (canAccessTenant(tenantId) && validAssetWrite(request.resource.data));
      allow delete: if isTenantAdmin(tenantId);
    }

    // -------------------------------------------------------------------------
    // Tenant-scoped: bookings
    // -------------------------------------------------------------------------
    match /tenants/{tenantId}/bookings/{bookingId} {
      allow read: if canAccessTenant(tenantId);
      allow create: if canAccessTenant(tenantId) && validNewBooking(request.resource.data);
      allow update: if isTenantAdmin(tenantId) || (canAccessTenant(tenantId) && validBookingReturn(request.resource.data, resource.data));
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // Tenant-scoped: audit log
    // -------------------------------------------------------------------------
    match /tenants/{tenantId}/auditLog/{logId} {
      allow read: if isTenantAdmin(tenantId);
      allow create: if canAccessTenant(tenantId) && validAuditEntry(request.resource.data);
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // Root: adminUsers — global, not per-tenant
    // -------------------------------------------------------------------------
    match /adminUsers/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // Legacy root collections (kept as backup — read-only, admin only)
    // -------------------------------------------------------------------------
    match /assets/{assetId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
    match /bookings/{bookingId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
    match /auditLog/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Validation helpers
    // -------------------------------------------------------------------------
    function validAssetWrite(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() <= 50
        && data.location is string && data.location.size() > 0 && data.location.size() <= 100
        && data.updatedAt is timestamp
        && (!('description' in data) || (data.description is string && data.description.size() <= 500))
        && (!('partNo' in data) || (data.partNo is string && data.partNo.size() <= 100))
        && (!('condition' in data) || data.condition in ['good', 'attention', 'damaged'])
        && (!('status' in data) || data.status in ['in', 'out'])
        && (!('currentBookingId' in data) || data.currentBookingId == null || (data.currentBookingId is string && data.currentBookingId.size() <= 128))
        && !('deleted' in data)
        && !('deletedAt' in data);
    }

    function validNewBooking(data) {
      return data.assetId is string && data.assetId.size() > 0 && data.assetId.size() <= 50
        && data.bookedBy is string && data.bookedBy.size() > 0 && data.bookedBy.size() <= 100
        && data.destination is string && data.destination.size() > 0 && data.destination.size() <= 200
        && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000))
        && data.bookedAt is timestamp
        && data.returnedAt == null;
    }

    function validAuditEntry(data) {
      return data.action in ['asset_edited', 'asset_booked_out', 'asset_returned', 'asset_deleted', 'asset_restored', 'asset_purged']
        && data.assetId is string && data.assetId.size() > 0 && data.assetId.size() <= 50
        && data.performedBy is string && data.performedBy.size() > 0 && data.performedBy.size() <= 200
        && data.timestamp is timestamp;
    }

    function validBookingReturn(newData, oldData) {
      return newData.returnedAt is timestamp
        && oldData.returnedAt == null
        && newData.assetId == oldData.assetId
        && newData.bookedBy == oldData.bookedBy
        && newData.destination == oldData.destination
        && newData.bookedAt == oldData.bookedAt;
    }
  }
}
